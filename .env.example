CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
BASE_RPC_URL=https://mainnet.base.org

# Scout's OWN CROO agent key
CROO_SDK_KEY=croo_sk_your_scout_key_here

# The PulseBNB Agent that Scout pays (downstream A2A dependency)
PULSEBNB_SERVICE_ID=f8371fd3-1194-4b9e-ae5e-d500854cbf18
PULSEBNB_API=https://pulsebnb-api.baserep.xyz

# Cost control
SCOUT_MAX_DEPLOYMENTS=3
ETHERSCAN_API_KEY=your_etherscan_key_optional
